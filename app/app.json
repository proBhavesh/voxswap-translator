{
  "expo": {
    "name": "VoxSwap",
    "slug": "voxswap",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "voxswap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.voxswap.translator",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VoxSwap needs microphone access to capture your speech for translation.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.voxswap.translator",
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_STATE",
        "ACCESS_NETWORK_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1a2e"
        }
      ],
      "onnxruntime-react-native",
      "./plugins/with-large-heap"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
