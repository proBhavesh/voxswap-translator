<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <!-- Header row -->
    <View
        android:id="@+id/statusDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/circle_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/statusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/status_ready"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/statusDot"
        app:layout_constraintStart_toEndOf="@id/statusDot"
        app:layout_constraintTop_toTopOf="@id/statusDot" />

    <TextView
        android:id="@+id/retryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:text="@string/retry"
        android:textColor="@color/brand_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/statusDot"
        app:layout_constraintStart_toEndOf="@id/statusLabel"
        app:layout_constraintTop_toTopOf="@id/statusDot" />

    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/title_activity_settings"
        android:scaleType="center"
        android:src="@drawable/settings_icon"
        app:tint="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Language bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/languageBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/bg_secondary"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_light"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settingsButton">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <ImageView
                android:id="@+id/languageIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_language"
                app:tint="@color/brand_primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/sourceLanguageName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/loading"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/languageIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/arrowIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/right_arrow_icon"
                app:tint="@color/text_muted"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/sourceLanguageName"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/targetLanguagesText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/loading"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/chevronIcon"
                app:layout_constraintStart_toEndOf="@id/arrowIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/chevronIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_muted"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Mic glow ring -->
    <View
        android:id="@+id/micGlow"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circle_glow"
        app:layout_constraintBottom_toTopOf="@id/statusText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/languageBar"
        app:layout_constraintVertical_bias="0.45" />

    <!-- Mic button -->
    <ImageButton
        android:id="@+id/micButton"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circle_brand"
        android:contentDescription="@string/mic"
        android:scaleType="center"
        android:src="@drawable/mic_icon"
        app:tint="@color/text_inverse"
        app:layout_constraintBottom_toBottomOf="@id/micGlow"
        app:layout_constraintEnd_toEndOf="@id/micGlow"
        app:layout_constraintStart_toStartOf="@id/micGlow"
        app:layout_constraintTop_toTopOf="@id/micGlow" />

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/tap_to_start"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/captionCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Caption area -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/captionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:minHeight="80dp"
        app:cardBackgroundColor="@color/bg_secondary"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_light"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/captionActionsRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/captionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="80dp"
            android:padding="16dp"
            android:text="@string/captions_placeholder"
            android:textColor="@color/text_muted"
            android:textSize="16sp" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Caption actions row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/captionActionsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/changeLanguagesButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/captionSaveIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_save"
            app:tint="@color/text_muted"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/captionSaveStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/caption_saving"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/captionSaveIcon"
            app:layout_constraintTop_toTopOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Change Languages button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/changeLanguagesButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:text="@string/change_languages"
        android:textColor="@color/brand_primary"
        app:cornerRadius="12dp"
        app:strokeColor="@color/brand_primary"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
